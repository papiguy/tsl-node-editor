{
  "private": true,
  "description": "Node-based editor for building Three.js TSL materials with WebGPU preview and export.",
  "license": "MIT",
  "author": "Takahiro",
  "repository": {
    "type": "git",
    "url": "https://github.com/takahirox/tsl-node-editor.git"
  },
  "homepage": "https://github.com/takahirox/tsl-node-editor",
  "bugs": {
    "url": "https://github.com/takahirox/tsl-node-editor/issues"
  },
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/tsl-node-editor && npm run build -w examples/basic && npm run build -w examples/material-editor",
    "dev": "npm run dev -w examples/basic",
    "lint": "eslint .",
    "test": "npm test -w packages/tsl-node-editor",
    "preview": "npm run preview -w examples/basic"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4"
  }
}
