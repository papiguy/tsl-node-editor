{
  "name": "@ni2khanna/tsl-node-editor",
  "version": "1.0.0",
  "description": "Node-based editor for building Three.js TSL materials with WebGPU preview and export.",
  "type": "module",
  "license": "MIT",
  "author": "Takahiro & Nitin Khanna",
  "main": "./dist/tsl-node-editor.js",
  "module": "./dist/tsl-node-editor.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/tsl-node-editor.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/tsl-node-editor.css",
    "./viewer": {
      "import": "./src/viewer.ts"
    },
    "./basis/*": "./public/basis/*"
  },
  "files": [
    "dist",
    "src/viewer.ts",
    "public/basis"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.182.0"
  },
  "dependencies": {
    "@takahirox/gltf-three-materials-tsl-exporter": "^0.3.0",
    "toastywave": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.1.0"
  }
}
